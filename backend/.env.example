# Sunucu (Render PORT otomatik atanır)
PORT=4000

# Supabase PostgreSQL bağlantısı — Project Settings → Database → Connection string (URI)
# Örnek: postgresql://postgres.[ref]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# JWT imzalama anahtarı (üretimde güçlü ve gizli bir değer kullanın)
JWT_SECRET=guclu_ve_uzun_gizli_anahtar_degistir

# Vercel frontend — tam köken (https://....vercel.app); birden fazlaysa virgülle ayırın
CLIENT_ORIGIN=https://your-app.vercel.app
